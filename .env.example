DF_API_TOKEN=replace_with_deltaforce_api_token
DF_API_BASE_URL=https://orzice.com/workApi
REFRESH_COOLDOWN_MS=600000

# local for development, cloudbase for CloudBase function runtime.
STORAGE_MODE=local
LOCAL_DATA_DIR=data/serverless-cache
PUBLIC_ASSET_BASE_URL=

# CloudBase runtime values.
TCB_ENV_ID=
TCB_CACHE_COLLECTION=df_cache

# Frontend build value. Use the CloudBase HTTP function public URL.
VITE_API_BASE_URL=
