{
  "name": "deltaforce-backend",
  "version": "2.0.0",
  "type": "commonjs",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/local-server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/local-server.js"
  },
  "cloudbaseFunction": {
    "runtime": "Nodejs20.0",
    "timeout": 30,
    "memorySize": 256,
    "type": "web"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.3",
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
